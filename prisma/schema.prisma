generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  GERANT
  MAGASINIER
  VENDEUR
  RESPONSABLE_ACHAT
}

enum Format {
  SACHET
  BOUTEILLE
  BONBONNE
}

enum ProduitType {
  VENTE
  ACHAT
  SERVICE
  CONSOMMABLE_INTERNE
}

enum CommandeStatut {
  EN_ATTENTE
  VALIDEE
  RECUE // Changé de LIVREE à RECUE pour correspondre aux achats
}

enum TransactionType {
  RECETTE
  DEPENSE
}

enum RapportType {
  JOURNALIER
  MENSUEL
}

enum NotificationType {
  STOCK_FAIBLE
  LIVRAISON_PREVUE
}

enum StockMovementType {
  ENTREE
  SORTIE
}

model Magasin {
  idMagasin    String       @id @default(uuid())
  nom          String       @unique
  adresse      String
  utilisateurs Utilisateur[]
  stocks       Stock[]
  ventes       Vente[]
  destockages  Destockage[]
  commandes    Commande[]   // Achats liés à un magasin
  transfersEnvoyes StockTransfer[] @relation("SourceTransfer")
  transfersRecus   StockTransfer[] @relation("DestinationTransfer")
  createdAt    DateTime     @default(now())

  @@map("magasins")
}

model Utilisateur {
  idUtilisateur String   @id @default(uuid())
  nom           String
  email         String   @unique
  role          Role
  motDePasse    String
  magasinId     String?
  magasin       Magasin? @relation(fields: [magasinId], references: [idMagasin])
  createdAt     DateTime @default(now())

  @@map("utilisateurs")
}

model Client {
  idClient   String    @id @default(uuid())
  nomClient  String
  telephone  String
  adresse    String
  ventes     Vente[]   // Client lié directement aux ventes plutôt qu'aux commandes d'achat
  createdAt  DateTime  @default(now())

  @@map("clients")
}

model Produit {
  codeProduit  String   @id
  nomProduit   String
  format       Format
  type         ProduitType @default(VENTE)
  categorie    String
  prixUnitaire Float
  fournisseur  String
  stocks       Stock[]
  destockages  Destockage[]
  lignesVente  LigneVente[]
  notifications Notification[]
  mouvements   StockMovement[]
  commandes    Commande[]
  transfers    StockTransfer[]

  @@map("produits")
}

model Stock {
  idStock      String   @id @default(uuid())
  produitId    String
  produit      Produit  @relation(fields: [produitId], references: [codeProduit])
  magasinId    String
  magasin      Magasin  @relation(fields: [magasinId], references: [idMagasin])
  quantite     Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([produitId, magasinId])
  @@map("stocks")
}

model Destockage {
  idDestock    String   @id @default(uuid())
  produitId    String
  produit      Produit  @relation(fields: [produitId], references: [codeProduit])
  magasinId    String
  magasin      Magasin  @relation(fields: [magasinId], references: [idMagasin])
  quantite     Int
  motif        String
  date         DateTime @default(now())
  userId       String
  // utilisateur  Utilisateur @relation(fields: [userId], references: [idUtilisateur])

  @@map("destockages")
}

model Commande {
  idCommande   String           @id @default(uuid())
  dateCommande DateTime         @default(now())
  statut       CommandeStatut   @default(EN_ATTENTE)
  fournisseurId String?         // ID du fournisseur (optionnel pour l'instant)
  produitId    String
  produit      Produit          @relation(fields: [produitId], references: [codeProduit])
  quantite     Int
  magasinId    String
  magasin      Magasin          @relation(fields: [magasinId], references: [idMagasin])
  responsableAchatId String
  // responsableAchat Utilisateur @relation(fields: [responsableAchatId], references: [idUtilisateur])

  @@map("commandes")
}

model Vente {
  idVente      String   @id @default(uuid())
  dateVente    DateTime @default(now())
  montantTotal Float
  modePaiement String
  magasinId    String
  magasin      Magasin  @relation(fields: [magasinId], references: [idMagasin])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [idClient])
  vendeurId    String
  lignes       LigneVente[]
  facture      Facture?
  transaction  Transaction?

  @@map("ventes")
}

model LigneVente {
  idLigne      String   @id @default(uuid())
  venteId      String
  vente        Vente    @relation(fields: [venteId], references: [idVente])
  produitId    String
  produit      Produit  @relation(fields: [produitId], references: [codeProduit])
  quantite     Int
  prixUnitaire Float
  totalLigne   Float

  @@map("lignes_vente")
}

model StockTransfer {
  id                    String   @id @default(uuid())
  produitId             String
  produit               Produit  @relation(fields: [produitId], references: [codeProduit])
  sourceMagasinId       String
  sourceMagasin         Magasin  @relation("SourceTransfer", fields: [sourceMagasinId], references: [idMagasin])
  destinationMagasinId  String
  destinationMagasin    Magasin  @relation("DestinationTransfer", fields: [destinationMagasinId], references: [idMagasin])
  quantite              Int
  motif                 String?
  userId                String
  date                  DateTime @default(now())

  @@map("stock_transfers")
}

model Facture {
  idFacture     String   @id @default(uuid())
  numeroFacture String
  dateFacture   DateTime @default(now())
  montant       Float
  venteId       String   @unique
  vente         Vente    @relation(fields: [venteId], references: [idVente])

  @@map("factures")
}

model Transaction {
  idTransaction String   @id @default(uuid())
  typeTransaction TransactionType
  categorie     String
  description   String?
  montant       Float
  reference     String?
  venteId       String?  @unique
  vente         Vente?   @relation(fields: [venteId], references: [idVente])
  createdAt     DateTime @default(now())

  @@map("transactions")
}

model Rapport {
  idRapport        String      @id @default(uuid())
  typeRapport      RapportType
  periode          String
  donneesStatistiques Json
  createdAt        DateTime    @default(now())

  @@map("rapports")
}

model StockMovement {
  id            String              @id @default(uuid())
  codeProduit   String
  produit       Produit             @relation(fields: [codeProduit], references: [codeProduit], onDelete: Cascade)
  type          StockMovementType
  quantite      Int
  magasinId     String?             // Ajout magasin_id pour traçabilité
  motif         String
  createdBy     String?
  createdAt     DateTime            @default(now())

  @@map("stock_movements")
}

model Notification {
  idNotification String           @id @default(uuid())
  type           NotificationType
  message        String
  dateEnvoi      DateTime         @default(now())
  produitId      String?
  produit        Produit?         @relation(fields: [produitId], references: [codeProduit])

  @@map("notifications")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
}

model Bilan {
  idBilan         String   @id @default(uuid())
  exercice        String
  actifImmobilise Float    @default(0)
  actifCirculant  Float    @default(0)
  totalActif      Float    @default(0)
  capitauxPropres Float    @default(0)
  dettes          Float    @default(0)
  totalPassif     Float    @default(0)
  generePar       String
  createdAt       DateTime @default(now())

  @@map("bilans")
}

model AuditLog {
  idAudit      String      @id @default(uuid())
  action       AuditAction
  entite       String
  idEntite     String
  userId       String?
  ancienValeurs Json?
  nouveauValeurs Json?
  createdAt    DateTime    @default(now())

  @@map("audit_logs")
}